# Gemini (optional)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="http://localhost:3000"

# MongoDB Atlas — required (app + Hostinger deployment)
MONGODB_URI_ATLAS="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="db_liquid"

# Local dev API port (Vite proxies /api here)
API_PORT=3001

# Hostinger / cloud sets PORT automatically — do not need to set locally
