# Gemini (optional)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="http://localhost:3000"

# MongoDB — required for shared buyer/seller data
# Local Compass / mongod:
MONGODB_URI="mongodb://localhost:27017/"
MONGODB_DB="db_liquid"

# MongoDB Atlas (cloud) — paste your connection string here after migration:
# MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority"
# Used only by: npm run migrate:atlas (copies local data → Atlas)
# MONGODB_URI_ATLAS="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority"

API_PORT=3001
